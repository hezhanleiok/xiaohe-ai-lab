---
const { title = "小何AI实验室" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="专注 AI 工具测评与实战分享 | 生图 · 生视频 · AI效率工具" />

    <!-- 字体：现代中英混排 -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Tailwind 会自动注入 -->
  </head>
  <body class="bg-gemini-gradient min-h-screen text-white font-sans antialiased">
    <header class="py-6 px-6 md:px-12 bg-black/30 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-300 to-purple-400">小何AI实验室</a>
        <div class="space-x-8 text-lg">
          <a href="/" class="hover:text-indigo-300 transition">首页</a>
          <a href="/blog" class="hover:text-indigo-300 transition">博客</a>
          <a href="/about" class="hover:text-indigo-300 transition">关于</a>
        </div>
      </nav>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="py-10 text-center text-slate-400 border-t border-slate-700/50 bg-black/20">
      <p>© 2026 小何AI实验室 · <a href="/privacy-policy" class="hover:text-indigo-300">隐私政策</a></p>
    </footer>
  </body>
</html>
