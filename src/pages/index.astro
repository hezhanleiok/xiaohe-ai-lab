---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="小何AI实验室 - AI工具测评与实战">
  <section class="min-h-[80vh] flex items-center justify-center px-6 py-20">
    <div class="text-center max-w-5xl mx-auto space-y-8 md:space-y-12">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-indigo-300 via-purple-300 to-pink-300">
        小何AI实验室
      </h1>

      <p class="text-2xl md:text-4xl font-medium text-slate-200">
        专注 AI 工具测评与实战分享
      </p>

      <p class="text-lg md:text-2xl text-slate-300 max-w-4xl mx-auto leading-relaxed">
        生图 · 生视频 · AI效率工具 · Midjourney · Stable Diffusion · Runway · Kling 等最新干货与实战经验
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-6 mt-10">
        <a href="/blog" class="px-10 py-5 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 rounded-full text-xl font-semibold shadow-2xl shadow-indigo-500/40 transition-all duration-300 hover:scale-105">
          探索最新博客
        </a>
        <a href="/about" class="px-10 py-5 border-2 border-indigo-400/60 hover:bg-indigo-900/30 rounded-full text-xl font-semibold transition-all duration-300 hover:scale-105">
          了解更多
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
