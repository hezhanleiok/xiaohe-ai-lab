---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="小何AI实验室 - AI工具测评与实战">
  <div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 bg-clip-text text-transparent bg-gradient-to-r from-indigo-300 via-purple-300 to-pink-300">
        小何AI实验室
      </h1>
      
      <p class="text-xl md:text-3xl text-slate-300 mb-8 leading-relaxed">
        专注 AI 工具测评与实战分享
      </p>
      
      <p class="text-lg md:text-xl text-slate-400 mb-12 max-w-3xl mx-auto">
        生图 · 生视频 · AI效率工具 · Midjourney · Stable Diffusion · Runway · Kling 等最新实战干货
      </p>

      <div class="flex flex-wrap justify-center gap-6">
        <a href="/blog" class="px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 rounded-full text-lg font-medium shadow-lg shadow-indigo-500/30 transition-all duration-300 transform hover:scale-105">
          探索最新博客
        </a>
        <a href="/about" class="px-8 py-4 border border-indigo-400/50 hover:bg-indigo-900/30 rounded-full text-lg font-medium transition-all duration-300">
          关于我
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
